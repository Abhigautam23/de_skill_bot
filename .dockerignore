# Mirrors .gitignore but tighter — keeps secrets and dev junk out of the image.

# Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Python build / cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Git / VCS
.git/
.gitignore
.gitattributes

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker / fly meta — not needed inside the image itself
Dockerfile
.dockerignore
fly.toml

# Logs / debug output
*.log
logs/
out.txt
debug.txt

# Local DBs
*.sqlite
*.sqlite3
*.db

# Docs (optional — uncomment if you don't want them in the image)
# *.md
# README*
